<file path="public/css/styles.css">
*,
*::before,
*::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html {
    height: 100%;
}

body {
    margin: 0;
    box-sizing: border-box;
    font-family: system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    height: 100%;
    color: #0f172a;
    background: #eef2f6;
    line-height: 1.5;
}

body.app {
    min-height: 100%;
}

/* --------------------------------------------------------------------------
   Estructura general
   -------------------------------------------------------------------------- */

.app-shell {
    display: grid;
    grid-template-columns: 260px minmax(0, 1fr);
    min-height: 100vh;
    width: 100%;
}

/* --------------------------------------------------------------------------
   Menú lateral
   -------------------------------------------------------------------------- */

.sidebar {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    background: linear-gradient(180deg, #6b0f0f 0%, #4a0a0a 100%);
    color: #ffffff;
    box-shadow: 4px 0 24px rgba(0, 0, 0, 0.12);
}

.sidebar__header {
    padding: 1.5rem 1.25rem 1.25rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
}

.sidebar__brand-title {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: #ffffff;
}

.sidebar__brand-subtitle {
    margin-top: 0.25rem;
    font-size: 0.8125rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.72);
}

.sidebar__nav {
    flex: 1;
    padding: 0.75rem 0 1rem;
    overflow-y: auto;
}

.sidebar__menu,
.nav-list {
    list-style: none;
}

.sidebar__item,
.nav-item {
    margin: 0.25rem 0.75rem;
}

.sidebar__link,
.nav-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    color: rgba(255, 255, 255, 0.92);
    text-decoration: none;
    font-size: 0.9375rem;
    font-weight: 500;
    border-radius: 0.5rem;
    border: 1px solid transparent;
    transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
}

.sidebar__link-icon,
.nav-link__icon {
    flex-shrink: 0;
    width: 1.25rem;
    height: 1.25rem;
    border-radius: 0.25rem;
    background: rgba(255, 255, 255, 0.18);
}

.sidebar__link-text,
.nav-link__text {
    flex: 1;
}

.sidebar__link:hover,
.nav-link:hover {
    background: rgba(255, 255, 255, 0.1);
    color: #ffffff;
}

.sidebar__item--active .sidebar__link,
.nav-item--active .nav-link {
    background: rgba(255, 255, 255, 0.16);
    color: #ffffff;
    font-weight: 600;
    border-color: rgba(255, 255, 255, 0.28);
    box-shadow: inset 3px 0 0 #fca5a5;
}

.sidebar__item--active .sidebar__link-icon,
.nav-item--active .nav-link__icon {
    background: rgba(255, 255, 255, 0.35);
}

.sidebar__footer {
    padding: 1rem 1.25rem;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
}

.sidebar__footer-text {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.55);
}

/* --------------------------------------------------------------------------
   Columna principal (header + contenido)
   -------------------------------------------------------------------------- */

.app-main {
    display: flex;
    flex-direction: column;
    min-width: 0;
    min-height: 100vh;
    background: #eef2f6;
}

/* --------------------------------------------------------------------------
   Barra superior
   -------------------------------------------------------------------------- */

.header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
    height: 64px;
    padding: 0 1.75rem;
    background: #ffffff;
    box-shadow: 0 2px 8px rgba(15, 23, 42, 0.08);
    z-index: 10;
}

.header__section {
    display: flex;
    align-items: center;
}

.header__section--title {
    flex: 1;
    min-width: 0;
}

.header__section--profile {
    flex-shrink: 0;
    margin-left: 1rem;
}

.header__module-title {
    font-size: 1.375rem;
    font-weight: 700;
    color: #0f172a;
    line-height: 1.2;
}

.header__profile,
.profile-card {
    display: flex;
    flex-direction: row-reverse;
    align-items: center;
    gap: 0.875rem;
}

.header__profile-info,
.profile-card__info {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    text-align: right;
}

.header__profile-name,
.profile-card__name {
    font-size: 0.9375rem;
    font-weight: 600;
    color: #0f172a;
}

.header__profile-role,
.profile-card__role {
    font-size: 0.8125rem;
    color: #64748b;
}

.header__profile-photo,
.profile-card__avatar {
    margin: 0;
    flex-shrink: 0;
}

.header__profile-image,
.profile-card__image {
    display: block;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid #e2e8f0;
}

.header__profile-placeholder,
.profile-card__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: #b91c1c;
    color: #ffffff;
    border: 2px solid #fecaca;
}

.header__profile-initials,
.profile-card__initials {
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.03em;
}

/* --------------------------------------------------------------------------
   Contenido central
   -------------------------------------------------------------------------- */

.app-content {
    flex: 1;
    overflow-y: auto;
    padding: 1.75rem 2rem 2rem;
    background: #eef2f6;
}

/* --------------------------------------------------------------------------
   Módulos (vistas inyectadas por el Router)
   -------------------------------------------------------------------------- */

.module__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.5rem;
}

.module__title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #0f172a;
}

.module__error {
    padding: 1rem 1.25rem;
    color: #991b1b;
    background: #fef2f2;
    border-radius: 0.5rem;
    border: 1px solid #fecaca;
}

/* --------------------------------------------------------------------------
   Responsive
   -------------------------------------------------------------------------- */

@media (max-width: 768px) {
    .app-shell {
        grid-template-columns: 1fr;
    }

    .sidebar {
        min-height: auto;
        box-shadow: none;
    }

    .sidebar__nav {
        padding-bottom: 0.5rem;
    }

    .sidebar__menu,
    .nav-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.25rem;
        padding: 0 0.5rem;
    }

    .sidebar__item,
    .nav-item {
        margin: 0;
    }

    .header {
        padding: 0 1rem;
        height: auto;
        min-height: 64px;
        flex-wrap: wrap;
        gap: 0.75rem;
        padding-top: 0.75rem;
        padding-bottom: 0.75rem;
    }

    .app-content {
        padding: 1.25rem 1rem 1.5rem;
    }
}

